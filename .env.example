# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
AUTH_SECRET="replace-with-long-random-secret"

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/wai_sales_assistant?schema=public"

# OpenAI
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4.1-mini"

# WhatsApp Provider (WAHA)
WHATSAPP_PROVIDER="waha"
WAHA_BASE_URL="http://localhost:3000"
WAHA_SESSION="default"
WAHA_API_KEY=""
WAHA_WEBHOOK_SECRET=""
WAHA_REQUEST_TIMEOUT_MS="15000"

# Auto reply
AUTO_REPLY_ENABLED="true"

# Seed optional overrides
SEED_ADMIN_EMAIL=""
SEED_ADMIN_PASSWORD=""

# Deprecated (Fonnte legacy only)
SEED_FONNTE_TOKEN=""
FONNTE_TOKEN=""
