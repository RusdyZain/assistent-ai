generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LeadStatus {
  hot
  warm
  cold
  complaint
  deal
  lost
}

enum ConversationStatus {
  open
  closed
  rate_limited
}

enum MessageDirection {
  incoming
  outgoing
}

enum OrderStatus {
  draft
  confirmed
  waiting_payment
  paid
  cancelled
  completed
}

enum FollowUpStatus {
  pending
  sent
  cancelled
}

enum MessageSendStatus {
  pending
  sent
  failed
  blocked
}

enum ProductType {
  product
  service
}

enum ReplyTemplateType {
  greeting
  ask_price
  ask_stock
  ask_location
  ask_booking
  ask_payment
  order_recap
  follow_up_warm
  follow_up_hot
  payment_reminder
  complaint_response
  closing_message
}

enum KnowledgeCategory {
  address
  payment
  booking
  shipping
  refund
  reschedule
  promo
  faq
  other
}

model Business {
  id                           String   @id @default(cuid())
  name                         String
  ownerName                    String
  phone                        String
  businessCategory             String?
  businessDescription          String?
  businessLocation             String?
  serviceArea                  String?
  operatingHours               String?
  whatsappNumber               String?
  replyLanguage                String   @default("Indonesia")
  brandTone                    String   @default("friendly")
  acceptsCOD                   Boolean  @default(false)
  acceptsTransfer              Boolean  @default(true)
  acceptsQRIS                  Boolean  @default(false)
  requiresDownPayment          Boolean  @default(false)
  downPaymentAmount            Decimal? @db.Decimal(12, 2)
  downPaymentPercentage        Int?
  allowNegotiation             Boolean  @default(false)
  minimumOrder                 Decimal? @db.Decimal(12, 2)
  refundPolicy                 String?
  reschedulePolicy             String?
  shippingPolicy               String?
  paymentInstructions          String?
  orderProcess                 String?
  warmLeadFollowUpHours        Int      @default(24)
  hotLeadFollowUpHours         Int      @default(2)
  closingPriorityFollowUpHours Int      @default(1)
  waitingPaymentFollowUpHours  Int      @default(6)
  maxFollowUpCount             Int      @default(2)
  markLostAfterDays            Int      @default(3)
  setupCompleted               Boolean  @default(false)
  setupStep                    Int      @default(1)
  fonnteToken                  String?
  email                        String   @unique
  passwordHash                 String
  dailyMessageLimit            Int      @default(500)
  perCustomerDailyLimit        Int      @default(20)
  replyCooldownSeconds         Int      @default(3)
  inboundOnlyMode              Boolean  @default(true)
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt

  customers          Customer[]
  conversations      Conversation[]
  messages           Message[]
  messageSendLogs    MessageSendLog[]
  products           Product[]
  replyTemplates     ReplyTemplate[]
  knowledgeBaseItems KnowledgeBaseItem[]
  orders             Order[]
  followUps          FollowUp[]
  webhookEvents      WebhookEvent[]
}

model Customer {
  id                 String     @id @default(cuid())
  businessId         String
  name               String?
  phone              String
  leadStatus         LeadStatus @default(cold)
  tags               String[]   @default([])
  optIn              Boolean    @default(true)
  spamSuspected      Boolean    @default(false)
  spamReason         String?
  lastIncomingAt     DateTime?
  lastOutgoingAt     DateTime?
  outgoingCountToday Int        @default(0)
  outgoingCountDate  DateTime?
  lastMessageAt      DateTime?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  business        Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  conversations   Conversation[]
  messages        Message[]
  messageSendLogs MessageSendLog[]
  orders          Order[]
  followUps       FollowUp[]

  @@unique([businessId, phone])
  @@index([businessId, leadStatus])
  @@index([businessId, lastMessageAt])
}

model Conversation {
  id            String             @id @default(cuid())
  businessId    String
  customerId    String
  status        ConversationStatus @default(open)
  summary       String?
  lastIntent    String?
  lastMessageAt DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  business        Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer        Customer         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  messages        Message[]
  messageSendLogs MessageSendLog[]
  orders          Order[]
  followUps       FollowUp[]

  @@index([businessId, status])
  @@index([customerId, status])
  @@index([businessId, lastMessageAt])
}

model Message {
  id             String           @id @default(cuid())
  businessId     String
  customerId     String
  conversationId String
  direction      MessageDirection
  message        String
  rawPayload     Json?
  fonnteInboxId  String?
  aiProcessed    Boolean          @default(false)
  createdAt      DateTime         @default(now())

  business     Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer     Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([businessId, createdAt])
  @@index([conversationId, createdAt])
  @@index([customerId, createdAt])
}

model MessageSendLog {
  id             String            @id @default(cuid())
  businessId     String
  customerId     String
  conversationId String?
  message        String
  status         MessageSendStatus @default(pending)
  blockedReason  String?
  fonnteResponse Json?
  createdAt      DateTime          @default(now())

  business     Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer     Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  @@index([businessId, status, createdAt])
  @@index([customerId, createdAt])
  @@index([conversationId, createdAt])
}

model Product {
  id             String      @id @default(cuid())
  businessId     String
  name           String
  type           ProductType @default(product)
  description    String?
  price          Decimal     @db.Decimal(12, 2)
  promoPrice     Decimal?    @db.Decimal(12, 2)
  benefits       String?
  suitableFor    String?
  stock          Int         @default(0)
  stockStatus    String?
  availability   String?
  duration       String?
  minimumOrder   Int?
  processingTime String?
  deliveryInfo   String?
  category       String?
  keywords       String[]    @default([])
  faq            Json?
  imageUrl       String?
  tags           String[]    @default([])
  isActive       Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, isActive])
  @@index([businessId, category])
}

model ReplyTemplate {
  id         String            @id @default(cuid())
  businessId String
  type       ReplyTemplateType
  title      String
  content    String
  isActive   Boolean           @default(true)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, type])
  @@index([businessId, isActive])
}

model KnowledgeBaseItem {
  id         String            @id @default(cuid())
  businessId String
  title      String
  category   KnowledgeCategory
  content    String
  isActive   Boolean           @default(true)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, category, isActive])
}

model Order {
  id             String      @id @default(cuid())
  businessId     String
  customerId     String
  conversationId String?
  status         OrderStatus @default(draft)
  items          Json
  totalEstimate  Decimal?    @db.Decimal(12, 2)
  notes          String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  business     Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer     Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  @@index([businessId, status])
  @@index([customerId])
  @@index([conversationId])
}

model FollowUp {
  id             String         @id @default(cuid())
  businessId     String
  customerId     String
  conversationId String?
  message        String
  scheduledAt    DateTime
  status         FollowUpStatus @default(pending)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  business     Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer     Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  @@index([businessId, status])
  @@index([scheduledAt])
}

model WebhookEvent {
  id         String   @id @default(cuid())
  businessId String
  payload    Json
  source     String   @default("fonnte")
  createdAt  DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, createdAt])
}
